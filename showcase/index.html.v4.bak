<!-- ══════════════════════════════════════════════════════════════════
     CHAPTER 8 — CLOSING CTA
     ══════════════════════════════════════════════════════════════════ -->
<section class="ch-close" id="pilot">
  <div class="close-inner">
    <div class="kicker rev" data-reveal>Closing · April 2026</div>
