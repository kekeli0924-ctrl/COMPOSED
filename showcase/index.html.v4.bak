    </h2>
    <p class="close-lede copy-mono rev" data-reveal style="text-align:center;">
      Composed is pre-launch. We're onboarding a small cohort of competitive youth teams for the first pilot block.
      <strong>Tell us your roster, your age group, and what you're actually trying to improve.</strong>
    </p>
    <div class="close-cta-row rev" data-reveal>
      <a class="cta primary" href="mailto:hello@composed.soccer?subject=Pilot%20interest%20%E2%80%94%20%5BClub%20%2F%20Team%20name%5D&body=Club%20or%20team%3A%0A%0AAge%20group%3A%0A%0ARoster%20size%3A%0A%0AHow%20you%20currently%20handle%20between-session%20training%3A%0A%0AWhat%20you're%20trying%20to%20actually%20improve%3A%0A">
        Bring Composed to your squad <span class="arrow">→</span>
      </a>
      <button class="cta ghost" id="copyBtn" type="button">Copy outreach template</button>
    </div>
    <div class="close-sig rev" data-reveal>Stay Composed.</div>
  </div>
</section>

<footer class="foot">
  <div class="foot-logo"><em>C</em>omposed</div>
  <div class="foot-note">A soccer training companion · Pre-launch · 2026</div>
</footer>

<script>
(function() {
  'use strict';

  const prefersReduce = matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ── Reveal system ────────────────────────────────────────────────
  // Tag generic reveal elements so they animate in on viewport entry.
  const rev = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      const delay = parseInt(e.target.dataset.delay || '0', 10);
      setTimeout(() => e.target.classList.add('in'), delay);
      rev.unobserve(e.target);
    });
  }, { threshold: 0.18, rootMargin: '0px 0px -8% 0px' });

  document.querySelectorAll('.rev, [data-reveal]').forEach(el => {
    if (!el.classList.contains('rev')) el.classList.add('rev');
    rev.observe(el);
  });

  // Mask-up for chapter heads
  const maskIO = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('in');
        maskIO.unobserve(e.target);
      }
    });
  }, { threshold: 0.4 });
  document.querySelectorAll('.mask-up').forEach(el => maskIO.observe(el));

  // ── Floating scroll-badge: fade out once the user has scrolled past hero ──
  const scrollBadge = document.getElementById('scrollBadge');
  const heroEl = document.querySelector('header.hero');

  function updateBadge() {
    if (!scrollBadge || !heroEl) return;
    const heroRect = heroEl.getBoundingClientRect();
    const past = heroRect.bottom < window.innerHeight * 0.3;
    scrollBadge.classList.toggle('fade', past);
  }

  // ── Ball-into-goal mechanic ──────────────────────────────────────
  const goalStage = document.querySelector('.goal-stage');
  const goalScene = document.getElementById('goalScene');
  const ballEl = document.getElementById('ball');

  function updateGoal() {
    if (!goalStage || !ballEl || !goalScene) return;
    const rect = goalStage.getBoundingClientRect();
    const scrollable = goalStage.offsetHeight - window.innerHeight;
    const scrolled = -rect.top;
    const progress = Math.max(0, Math.min(1, scrolled / scrollable));

    // Map progress (0..1) → ball.Y:
    //   - 0.00 - 0.20: ball hidden above frame (off-screen)
    //   - 0.20 - 0.65: ball descends into the goal (hits at 0.65)
    //   - 0.65 - 1.00: ball stays resting in the goal
    let t;
    if (progress < 0.20) {
      t = 0;
    } else if (progress < 0.65) {
      t = (progress - 0.20) / 0.45;
      // ease-in (gravity feel) — accelerate toward impact
      t = t * t;
    } else {
      t = 1;
    }
    // ballY maps from about -22rem (above) to +6rem (nestled near bottom)
    const startY = -22;
    const endY = 6;
    const y = startY + (endY - startY) * t;
    ballEl.style.setProperty('--ball-y', y + 'rem');

    // Background reveal + net-sway: only while INSIDE the goal-stage AND ball landed.
    // Once the user scrolls past the goal chapter, the page returns to dark so the
    // Pace chapter can land on the default ground.
    const insideGoal = rect.bottom > window.innerHeight * 0.2 && rect.top < window.innerHeight * 0.2;
    const landed = progress >= 0.65 && insideGoal;
    document.body.classList.toggle('warm-ground', landed);
    goalScene.classList.toggle('ball-landed', progress >= 0.65);
  }

  // ── Pace rotation: 7 stages — default + 6 positions ──────────────
  // Weights sourced from src/utils/pace.js (POSITION_WEIGHTS).
  const POSITIONS = [
    { key: 'Default', label: 'Default model',
      kicker: 'What is Pace',
      sub: 'Equal weights · no position set',
      body: 'Most training apps give every player the <strong>same score</strong>. A striker and a holding midfielder become the same number. It flattens the difference between what players are actually doing.',
      weights: { shooting: 20, passing: 20, consistency: 20, duration: 20, load: 20 },
      dom: null, posCode: '—', num: '20' },
    { key: 'Striker', label: 'Striker',
      kicker: 'Weighted by position',
      sub: 'Shooting-led · volume matters',
      body: 'A striker gets punished harder for missed finishing. <strong>40% of a striker\'s Pace</strong> comes from shooting — because that\'s what gets paid when the minute counts.',
      weights: { shooting: 40, passing: 10, consistency: 20, duration: 10, load: 20 },
      dom: 'shooting', posCode: '09', num: '40' },
    { key: 'Winger', label: 'Winger',
      kicker: 'Weighted by position',
      sub: 'Load-led · it\'s a running position',
      body: 'Wingers run. A lot. Their Pace leans on <strong>load</strong> and consistency — high-volume sprinting is the job description. Missed shots are noted, not punished.',
      weights: { shooting: 25, passing: 15, consistency: 20, duration: 15, load: 25 },
      dom: 'load', posCode: '07', num: '25' },
    { key: 'CAM', label: 'CAM · creator',
      kicker: 'Weighted by position',
      sub: 'Passing-led · finishing second',
      body: 'A creator gets rewarded for <strong>passing first</strong>. 30% passing, then finishing — the number tracks whether you\'re actually finding the runs ahead of you.',
      weights: { shooting: 25, passing: 30, consistency: 20, duration: 10, load: 15 },
      dom: 'passing', posCode: '10', num: '30' },
    { key: 'CDM', label: 'CDM · controller',
      kicker: 'Weighted by position',
      sub: 'Passing-led · shot-neutral',
      body: 'Not penalized for flat shot accuracy. A controller\'s Pace is <strong>35% passing, 5% shooting</strong> — because the job isn\'t to finish, it\'s to keep the next pass honest.',
      weights: { shooting: 5, passing: 35, consistency: 25, duration: 15, load: 20 },
      dom: 'passing', posCode: '06', num: '35' },
    { key: 'CB', label: 'Centre-back',
      kicker: 'Weighted by position',
      sub: 'Passing + duration-led',
      body: 'Distribution and minutes. A centre-back\'s Pace tracks <strong>passing</strong> and time on the ball — how many minutes did you play, and how cleanly did the ball move through you?',
      weights: { shooting: 5, passing: 30, consistency: 25, duration: 20, load: 20 },
      dom: 'passing', posCode: '04', num: '30' },
    { key: 'GK', label: 'Goalkeeper',
      kicker: 'Weighted by position',
      sub: 'Consistency + load-led',
      body: 'Not judged like a shooter. A keeper\'s Pace is <strong>30% consistency, 30% load</strong> — show up, do the work, and take the reps seriously. Shooting % is noise.',
      weights: { shooting: 5, passing: 15, consistency: 30, duration: 20, load: 30 },
      dom: 'load', posCode: '01', num: '30' },
  ];

  const paceKicker = document.getElementById('paceKicker');
  const paceNum = document.getElementById('paceNum');
  const paceSubLabel = document.getElementById('paceSubLabel');
  const paceBody = document.getElementById('paceBody');
  const paceStats = document.getElementById('paceStats');
  const pitchDots = document.querySelectorAll('.pitch-dot');
  const pitchZones = document.querySelectorAll('.pitch-zone');
  const paceGhostNum = document.getElementById('paceGhostNum');
  const paceProgressIndex = document.getElementById('paceProgressIndex');
  const paceProgressLabel = document.getElementById('paceProgressLabel');
  const paceStage = document.querySelector('.pace-stage');

  function snapText(el, val) {
    if (!el) return;
    if (prefersReduce) { el.textContent = val; return; }
    el.style.transition = 'opacity 180ms ease';
    el.style.opacity = '0';
    setTimeout(() => {
      el.textContent = val;
      el.style.opacity = '';
    }, 180);
  }

  function applyPosition(posIdx) {
    const pos = POSITIONS[posIdx];
    // Text updates with brief crossfade
    snapText(paceKicker, pos.kicker);
    snapText(paceSubLabel, pos.sub);
    // Big numeral — direct swap (it's a visual anchor, not a counter)
    if (paceNum) {
      paceNum.textContent = pos.num;
      paceNum.classList.toggle('accent-hit', pos.dom === 'shooting');
    }
    // Body — swap with opacity
    if (paceBody) {
      paceBody.style.opacity = '0';
      setTimeout(() => {
        paceBody.innerHTML = pos.body;
        paceBody.style.opacity = '';
      }, 220);
    }
    // Pace stats — update each stat's % + dominant treatment
    if (paceStats) {
      const metrics = ['shooting','passing','consistency','duration','load'];
      metrics.forEach((m) => {
        const cell = paceStats.querySelector(`[data-metric="${m}"]`);
        if (!cell) return;
        const val = cell.querySelector('.pace-stat-val');
        val.textContent = (pos.weights[m] != null ? pos.weights[m] : '—') + '%';
        val.classList.toggle('dominant', !!pos.dom && pos.dom === m);
      });
      // Position column
      const last = paceStats.querySelector('.pace-stat:last-child');
      if (last) last.querySelector('.pace-stat-val').textContent = pos.posCode;
    }
    // Pitch dots — light up the relevant role
    pitchDots.forEach(d => {
      const match = d.dataset.pos === pos.key || (pos.key === 'Winger' && d.dataset.pos === 'Winger-r') || (pos.key === 'CB' && d.dataset.pos === 'CB-r');
      d.classList.toggle('active', match);
      // dominant-accent highlight for shooting-led roles only
      d.classList.toggle('dominant-accent', match && pos.dom === 'shooting');
    });
    pitchZones.forEach(z => {
      z.classList.toggle('active', z.dataset.zone === pos.key);
    });
    // Ghost numeral — large faded digit, 1-indexed
    if (paceGhostNum) paceGhostNum.textContent = (posIdx + 1);
    if (paceProgressIndex) paceProgressIndex.textContent = String(posIdx + 1).padStart(2, '0');
    if (paceProgressLabel) paceProgressLabel.textContent = pos.label;
  }

  let lastPosIdx = -1;
  function updatePace() {
    if (!paceStage) return;
    const rect = paceStage.getBoundingClientRect();
    const scrollable = paceStage.offsetHeight - window.innerHeight;
    const scrolled = -rect.top;
    const progress = Math.max(0, Math.min(1, scrolled / scrollable));
    // Map progress to one of 7 stages, equal slices
    const idx = Math.min(POSITIONS.length - 1, Math.floor(progress * POSITIONS.length));
    if (idx !== lastPosIdx) {
      lastPosIdx = idx;
      applyPosition(idx);
    }
  }
  applyPosition(0);  // initial state

  // ── Unified scroll loop (rAF-throttled) ───────────────────────────
  let ticking = false;
  function onScroll() {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => {
      updateBadge();
      updateGoal();
      updatePace();
      ticking = false;
    });
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('resize', onScroll, { passive: true });
  onScroll();

  // ── Copy outreach template button ─────────────────────────────────
  const copyBtn = document.getElementById('copyBtn');
  if (copyBtn) {
    const TEMPLATE = `Subject: Pilot interest — [Club / Team name]

Club or team:
Age group:
Roster size:
How you currently handle between-session training:
What you're trying to actually improve:

(Anything else you want us to know:)`;
    copyBtn.addEventListener('click', () => {
      const orig = copyBtn.textContent;
      const showResult = (text) => {
        copyBtn.textContent = text;
        setTimeout(() => { copyBtn.textContent = orig; }, 2200);
      };
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(TEMPLATE).then(
          () => showResult('Copied — paste anywhere'),
          () => showResult('Copy failed — long-press to copy')
        );
      } else {
        showResult('Copy failed');
      }
    });
  }

})();
</script>
</body>
</html>
