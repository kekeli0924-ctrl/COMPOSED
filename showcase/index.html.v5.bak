    </nav>
    <div class="f-note">A soccer training companion · Pre-launch</div>
  </div>
</footer>

<script>
  (function() {
    'use strict';

    // ── Scroll progress bar ─────────────────────
    const scrollProgress = document.getElementById('scrollProgress');
    function updateScrollProgress() {
      const total = document.documentElement.scrollHeight - window.innerHeight;
      const pct = total > 0 ? (window.scrollY / total) * 100 : 0;
      scrollProgress.style.width = pct + '%';
    }

    // ── Nav scroll state ───────────────────────
    const nav = document.getElementById('topNav');
    function updateNav() {
      if (window.scrollY > 30) nav.classList.add('scrolled');
      else nav.classList.remove('scrolled');
    }

    // ── Reveal on scroll ────────────────────────
    const revealIO = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          revealIO.unobserve(e.target);
        }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -5% 0px' });
    document.querySelectorAll('.reveal').forEach(el => revealIO.observe(el));

    // ── Eyebrow stagger (120ms before headline) ────
    const eyebrowIO = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          eyebrowIO.unobserve(e.target);
        }
      });
    }, { threshold: 0.6, rootMargin: '0px 0px -20% 0px' });
    document.querySelectorAll('.eyebrow').forEach(el => eyebrowIO.observe(el));

    // ── Pace Intro chart draw ─────────────────────
    const chartLine = document.getElementById('paceChartLine');
    const chartIO = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          chartLine.classList.add('draw');
          chartIO.unobserve(e.target);
        }
      });
    }, { threshold: 0.4 });
    chartIO.observe(document.getElementById('paceChart'));

    // ── Hero ticker: count up to 847 on mount ────
    (function heroTicker() {
      const el = document.getElementById('heroTickerValue');
      if (!el) return;
      const prefersReduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
      const target = 6;
      if (prefersReduce) { el.textContent = target.toLocaleString(); return; }
      const start = performance.now();
      const dur = 1600;
      function tick(now) {
        const t = Math.min(1, (now - start) / dur);
        const eased = 1 - Math.pow(1 - t, 2.6);
        el.textContent = Math.round(target * eased).toLocaleString();
        if (t < 1) requestAnimationFrame(tick);
      }
      // small delay so it feels like it lands after the rest of the hero
      setTimeout(() => requestAnimationFrame(tick), 600);
    })();

    // ── Hero cursor-tilt phone (desktop only) ─────
    const heroPhone = document.getElementById('heroPhone');
    const heroEl = document.querySelector('header.hero');
    if (matchMedia('(hover: hover)').matches && heroPhone && heroEl) {
      let rafTilt = false;
      let pendingX = 0, pendingY = 0;
      heroEl.addEventListener('mouseenter', () => heroPhone.classList.add('tilting'));
      heroEl.addEventListener('mousemove', (e) => {
        const rect = heroEl.getBoundingClientRect();
        pendingX = (e.clientX - rect.left) / rect.width - 0.5;
        pendingY = (e.clientY - rect.top) / rect.height - 0.5;
        if (!rafTilt) {
          rafTilt = true;
          requestAnimationFrame(() => {
            const rotZ = -1.5 + pendingX * 2;
            const transY = pendingY * -3;
            heroPhone.style.transform = `rotate(${rotZ}deg) translateY(${transY}px)`;
            rafTilt = false;
          });
        }
      });
      heroEl.addEventListener('mouseleave', () => {
        heroPhone.style.transform = '';
        heroPhone.classList.remove('tilting');
      });
    }

    // ── Pace Payoff: ring draw + synchronized pct count-up ────
    (function paceoff() {
      const section = document.getElementById('pacePayoff');
      const pctEl = document.getElementById('payoffPct');
      if (!section || !pctEl) return;
      const target = 12.4;
      const prefersReduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (prefersReduce) {
        section.classList.add('visible');
        pctEl.textContent = target.toFixed(1);
        return;
      }
      const io = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          section.classList.add('visible');
          // Synchronize count-up with the 1.2s ring draw (delay 0.25s)
          const start = performance.now() + 250;
          const dur = 1200;
          function tick(now) {
            const t = Math.max(0, Math.min(1, (now - start) / dur));
            const eased = 1 - Math.pow(1 - t, 3);
            pctEl.textContent = (target * eased).toFixed(1);
            if (t < 1) requestAnimationFrame(tick);
          }
          requestAnimationFrame(tick);
          io.unobserve(entry.target);
        });
      }, { threshold: 0.4 });
      io.observe(section);
    })();

    // ── Pace Rotation: 3-phase scrollytelling ────
    // Real position weights from src/utils/pace.js (POSITION_WEIGHTS, including CB)
    const POSITIONS = [
      { key: 'Striker', label: 'Striker',
        weights: { shooting: 0.40, passing: 0.10, consistency: 0.20, duration: 0.10, load: 0.20 },
        dominant: 'shooting',
        caption: "Punished harder for missed finishing. <strong>40%</strong> of a striker's Pace comes from shooting." },
      { key: 'Winger', label: 'Winger',
        weights: { shooting: 0.25, passing: 0.15, consistency: 0.20, duration: 0.15, load: 0.25 },
        dominant: 'load',
        caption: "Measured on volume. A winger's Pace leans on <strong>load</strong> — it's a running position." },
      { key: 'CAM', label: 'CAM',
        weights: { shooting: 0.25, passing: 0.30, consistency: 0.20, duration: 0.10, load: 0.15 },
        dominant: 'passing',
        caption: "Rewarded for passing first. <strong>30%</strong> passing for a creator, then finishing." },
      { key: 'CDM', label: 'CDM',
        weights: { shooting: 0.05, passing: 0.35, consistency: 0.25, duration: 0.15, load: 0.20 },
        dominant: 'passing',
        caption: "Not penalized for flat shot accuracy. <strong>35%</strong> passing, <strong>5%</strong> shooting." },
      { key: 'CB', label: 'Centre-back',
        weights: { shooting: 0.05, passing: 0.30, consistency: 0.25, duration: 0.20, load: 0.20 },
        dominant: 'passing',
        caption: "Distribution and minutes. A CB's Pace tracks <strong>passing</strong> and time on the ball." },
      { key: 'GK', label: 'Goalkeeper',
        weights: { shooting: 0.05, passing: 0.15, consistency: 0.30, duration: 0.20, load: 0.30 },
        dominant: 'load',
        caption: "Not judged like a shooter. <strong>30%</strong> load, <strong>30%</strong> consistency — show up, do the work." }
    ];

    const METRIC_LABELS = [
      { key: 'shooting',    label: 'Shooting' },
      { key: 'passing',     label: 'Passing' },
      { key: 'consistency', label: 'Consistency' },
      { key: 'duration',    label: 'Duration' },
      { key: 'load',        label: 'Load' }
    ];

    const paceBars = document.getElementById('paceBars');
    const paceCaption = document.getElementById('paceCaption');
    const paceVizPosition = document.getElementById('paceVizPosition');
    const paceVizLabel = document.getElementById('paceVizLabel');
    const paceEyebrow = document.getElementById('paceEyebrow');
    const paceHeadline = document.getElementById('paceHeadline');
    const paceStage = document.getElementById('paceRotation');

    // Build initial bars (equal 20% each — Phase 1 default)
    function buildBars() {
      paceBars.innerHTML = METRIC_LABELS.map(m => `
        <div class="pace-bar-row" data-metric="${m.key}">
          <span class="pace-bar-label">${m.label}</span>
          <div class="pace-bar-track"><div class="pace-bar-fill" style="width: 50%;"></div></div>
          <span class="pace-bar-pct" data-pct="20">20%</span>
        </div>
      `).join('');
    }
    buildBars();

    // Number snap: old value blurs out, new enters from below. 40ms stagger
    // across metric rows top-to-bottom. Scoped to this chapter only.
    const prefersReduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
    function snapPct(el, to, staggerIdx = 0) {
      if (prefersReduceMotion) {
        el.textContent = to + '%';
        el.dataset.pct = to;
        return;
      }
      const delay = staggerIdx * 40;
      // clean up any pending animation state
      el.classList.remove('snap-in', 'snap-out');
      // trigger reflow to restart animation
      void el.offsetWidth;
      el.classList.add('snap-out');
      setTimeout(() => {
        el.textContent = to + '%';
        el.dataset.pct = to;
        el.classList.remove('snap-out');
        el.classList.add('snap-in');
        setTimeout(() => el.classList.remove('snap-in'), 260);
      }, 180 + delay);
    }

    // Ghost bar: captures the previous fill width so the viewer sees delta,
    // not just the end-state. Fades out 100ms into the new transition.
    function spawnGhost(track, prevWidthPx) {
      if (prefersReduceMotion || !prevWidthPx) return;
      const ghost = document.createElement('span');
      ghost.className = 'pace-bar-ghost';
      ghost.style.width = prevWidthPx + 'px';
      track.appendChild(ghost);
      // Trigger the fade after the new bar starts animating
      setTimeout(() => ghost.classList.add('fading'), 100);
      setTimeout(() => ghost.remove(), 500);
    }

    // Helper: apply a new set of weights to all bars with ghost-bar + number-snap.
    // 40ms stagger across metric rows, top-to-bottom, creates the cascading feel.
    function applyWeights(targets, opts) {
      const dominantKey = (opts && opts.dominantKey) || null;
      METRIC_LABELS.forEach((m, idx) => {
        const row = paceBars.querySelector(`[data-metric="${m.key}"]`);
        const track = row.querySelector('.pace-bar-track');
        const fill = row.querySelector('.pace-bar-fill');
        const pctEl = row.querySelector('.pace-bar-pct');
        const tgtPct = Math.round(targets[m.key] * 100);
        const cur = parseInt(pctEl.dataset.pct, 10) || 20;
        // Capture current fill width (px) BEFORE the new width transition fires
        const prevWidthPx = fill.getBoundingClientRect().width;
        fill.style.width = (tgtPct * 2.5) + '%';
        if (cur !== tgtPct) {
          spawnGhost(track, prevWidthPx);
          snapPct(pctEl, tgtPct, idx);
        }
        row.classList.toggle('dominant', !!dominantKey && m.key === dominantKey);
      });
    }

    const EQUAL = { shooting: 0.20, passing: 0.20, consistency: 0.20, duration: 0.20, load: 0.20 };

    function setPhase1() {
      paceEyebrow.textContent = 'The default model';
      paceHeadline.innerHTML = 'Most apps treat every player the same way.';
      paceCaption.innerHTML = 'Five metrics. Equal weights. One number for everyone.';
      paceVizLabel.textContent = 'Default · equal weights';
      paceVizPosition.textContent = 'All positions';
      applyWeights(EQUAL);
    }

    function setPhase2() {
      paceEyebrow.textContent = 'Pace · weighted by position';
      paceHeadline.innerHTML = 'Composed doesn\u2019t.';
      paceCaption.innerHTML = 'Each position gets its own weight table. The bars start to differentiate.';
      paceVizLabel.textContent = 'Weighting · in motion';
      paceVizPosition.textContent = 'shifting…';
      applyWeights(POSITIONS[0].weights);  // Striker = most dramatic shift
    }

    function setPhase3(positionIdx) {
      paceEyebrow.textContent = 'Pace · weighted by position';
      paceHeadline.innerHTML = 'Weighted to what the position actually does.';
      const pos = POSITIONS[positionIdx];
      paceVizLabel.textContent = 'Position weighting';
      paceVizPosition.textContent = pos.label.toUpperCase();
      paceCaption.style.opacity = '0';
      setTimeout(() => {
        paceCaption.innerHTML = pos.caption;
        paceCaption.style.opacity = '1';
      }, 180);
      applyWeights(pos.weights, { dominantKey: pos.dominant });
    }

    // Phase boundaries (out of 1.0):
    // 0.00 - 0.10  Phase 1 (equal)
    // 0.10 - 0.22  Phase 2 (differentiating)
    // 0.22 - 1.00  Phase 3 (cycle 6 positions, equal slices)
    let lastPhaseState = '';
    function updatePace() {
      const rect = paceStage.getBoundingClientRect();
      const winH = window.innerHeight;
      const scrollable = paceStage.offsetHeight - winH;
      const scrolled = -rect.top;
      const progress = Math.max(0, Math.min(1, scrolled / scrollable));

      let stateKey = '';
      if (progress < 0.10) {
        stateKey = 'p1';
        if (lastPhaseState !== stateKey) setPhase1();
      } else if (progress < 0.22) {
        stateKey = 'p2';
        if (lastPhaseState !== stateKey) setPhase2();
      } else {
        const p3progress = (progress - 0.22) / (1 - 0.22);
        const idx = Math.min(POSITIONS.length - 1, Math.floor(p3progress * POSITIONS.length));
        stateKey = 'p3-' + idx;
        if (lastPhaseState !== stateKey) setPhase3(idx);
      }
      lastPhaseState = stateKey;
    }

    // ── Video chapter: wide analysis board (Redesign 3) ──────────
    const videoStage = document.getElementById('videoStage');
    const board = document.getElementById('analysisBoard');
    const frameCountEl = document.getElementById('frameCount');
    const filmstripFrames = board ? board.querySelectorAll('.filmstrip-frame') : [];
    const filmstripArcFill = board ? board.querySelector('.filmstrip-arc-fill') : null;
    const resultNums = board ? board.querySelectorAll('.result-num') : [];

    const FRAME_TOTAL = 1247;
    let lastBoardState = -1;
    let lastFrameCount = -1;
    const resultAnims = new Map();  // track count-up rAF per row
    let resultsAnimatedFor = null;

    function animateResultNum(el, target) {
      const existing = resultAnims.get(el);
      if (existing) cancelAnimationFrame(existing);
      const start = performance.now();
      const dur = 850;
      function tick(now) {
        const t = Math.min(1, (now - start) / dur);
        const eased = 1 - Math.pow(1 - t, 3);
        el.textContent = Math.round(target * eased);
        if (t < 1) {
          resultAnims.set(el, requestAnimationFrame(tick));
        } else {
          resultAnims.delete(el);
        }
      }
      resultAnims.set(el, requestAnimationFrame(tick));
    }

    function updateVideo() {
      if (!videoStage || !board) return;
      const rect = videoStage.getBoundingClientRect();
      const winH = window.innerHeight;
      const scrollable = videoStage.offsetHeight - winH;
      const scrolled = -rect.top;
      const progress = Math.max(0, Math.min(1, scrolled / scrollable));

      // ── Frame counter: scroll-bound, counts up or down as scroll moves ──
      const targetFrames = Math.round(FRAME_TOTAL * progress);
      if (targetFrames !== lastFrameCount) {
        frameCountEl.textContent = targetFrames.toLocaleString();
        lastFrameCount = targetFrames;
      }

      // ── State mapping: 1 (capture) / 2 (extract) / 3 (analyze) ──
      let state = 1;
      if (progress >= 0.66) state = 3;
      else if (progress >= 0.33) state = 2;

      // ── Filmstrip: light frames sequentially within state 2's range ──
      if (state === 2 && filmstripFrames.length) {
        const innerProgress = Math.max(0, Math.min(1, (progress - 0.33) / 0.33));
        const litCount = Math.floor(innerProgress * filmstripFrames.length);
        filmstripFrames.forEach((f, i) => f.classList.toggle('lit', i < litCount));
        if (filmstripArcFill) {
          filmstripArcFill.style.strokeDasharray = `${Math.round(innerProgress * 100)} 100`;
        }
      } else if (state === 3) {
        // State 3: all frames stay lit
        filmstripFrames.forEach(f => f.classList.add('lit'));
        if (filmstripArcFill) filmstripArcFill.style.strokeDasharray = '100 100';
      } else {
        // State 1: all dim
        filmstripFrames.forEach(f => f.classList.remove('lit'));
        if (filmstripArcFill) filmstripArcFill.style.strokeDasharray = '0 100';
      }

      if (state === lastBoardState) return;
      lastBoardState = state;

      board.classList.remove('state-1', 'state-2', 'state-3');
      board.classList.add('state-' + state);

      // ── Count-up numbers once, when state 3 first activates ──
      if (state === 3 && resultsAnimatedFor !== 3) {
        resultNums.forEach(num => {
          const target = parseInt(num.dataset.target, 10) || 0;
          const prefersReduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
          if (prefersReduce) { num.textContent = target; return; }
          animateResultNum(num, target);
        });
        resultsAnimatedFor = 3;
      }
      // Reset count-up if the user scrolls back out of state 3 so it can replay
      if (state !== 3) resultsAnimatedFor = null;
      // In state 1, reset numbers to zero so the effect is authored
      if (state === 1) resultNums.forEach(num => num.textContent = '0');
    }

    // ── Threading pace line (scroll-bound dashoffset) ──
    const threadingPath = document.getElementById('threadingPath');
    const paceRotationEl = document.getElementById('paceRotation');
    const pacePayoffEl = document.getElementById('pacePayoff');
    const videoStageEl = document.getElementById('videoStage');
    const wrongMetricEl = document.querySelector('.ch-wrong');

    function updateThreading() {
      if (!threadingPath) return;
      const totalScrollable = document.documentElement.scrollHeight - window.innerHeight;
      const progress = totalScrollable > 0 ? window.scrollY / totalScrollable : 0;
      threadingPath.style.strokeDashoffset = String(Math.round(1000 * (1 - progress)));
    }

    // ── Thread-quiet scoping: fade threading line during scrollytelling zones ──
    function updateThreadQuiet() {
      if (!paceRotationEl || !pacePayoffEl || !videoStageEl) return;
      const winH = window.innerHeight;
      const rects = {
        rotation: paceRotationEl.getBoundingClientRect(),
        payoff: pacePayoffEl.getBoundingClientRect(),
        video: videoStageEl.getBoundingClientRect(),
      };
      const inQuiet =
        (rects.rotation.top < winH * 0.9 && rects.rotation.bottom > winH * 0.1) ||
        (rects.payoff.top < winH * 0.9 && rects.payoff.bottom > winH * 0.1) ||
        (rects.video.top < winH * 0.9 && rects.video.bottom > winH * 0.1);
      document.body.classList.toggle('thread-quiet', inQuiet);
    }

    // ── Handoff 1: mask-sweep hero → wrong metric (fires around the seam) ──
    const maskSweep = document.getElementById('maskSweep');
    const maskLine = maskSweep ? maskSweep.querySelector('.mask-sweep-line') : null;
    let handoff1State = 'idle';  // idle | sweeping | done
    function updateHandoff1() {
      if (!maskSweep || !maskLine || !wrongMetricEl) return;
      const heroRect = document.querySelector('header.hero').getBoundingClientRect();
      const wrongRect = wrongMetricEl.getBoundingClientRect();
      const winH = window.innerHeight;
      // Fire when hero is exiting (bottom near top of viewport) and wrong metric is below
      const heroExiting = heroRect.bottom < winH * 0.6 && heroRect.bottom > 0;
      if (heroExiting && handoff1State === 'idle') {
        handoff1State = 'sweeping';
        document.body.classList.add('handoff-active', 'handoff-1-active');
        maskSweep.classList.add('active');
        // Animate the hairline from top to bottom over 600ms
        maskLine.animate(
          [{ transform: 'translateY(0)' }, { transform: `translateY(${winH}px)` }],
          { duration: 600, easing: 'cubic-bezier(0.4, 0.0, 0.2, 1)', fill: 'forwards' }
        );
        setTimeout(() => {
          maskSweep.classList.remove('active');
          document.body.classList.remove('handoff-active', 'handoff-1-active');
          handoff1State = 'done';
        }, 650);
      } else if (heroRect.bottom >= winH * 0.6 && handoff1State === 'done') {
        // If user scrolls back up, reset so the handoff can fire again
        handoff1State = 'idle';
      }
    }

    // ── Handoff 2: dark → light as Pace Rotation ends and Payoff enters ──
    // Background transition is CSS-driven via body.payoff-lit class toggle.
    // Bars-collapse choreography: when the rotation's end is near the viewport top,
    // fade the rotation's weighting bars to zero width so the Payoff ring can "rise."
    function updateHandoff2() {
      if (!paceRotationEl || !pacePayoffEl) return;
      const rotationRect = paceRotationEl.getBoundingClientRect();
      const payoffRect = pacePayoffEl.getBoundingClientRect();
      const winH = window.innerHeight;
      // "In Payoff zone" = payoff top has crossed 70% of viewport AND payoff bottom still below top
      const inPayoff = payoffRect.top < winH * 0.7 && payoffRect.bottom > 0;
      document.body.classList.toggle('payoff-lit', inPayoff);
      // Bar collapse: when we're in the last 10% of the rotation, collapse bars
      const rotationScrollable = paceRotationEl.offsetHeight - winH;
      const rotationScrolled = -rotationRect.top;
      const rotationProgress = Math.max(0, Math.min(1, rotationScrolled / rotationScrollable));
      const bars = document.querySelectorAll('.pace-bar-fill');
      if (rotationProgress > 0.92) {
        const shrink = Math.max(0, Math.min(1, (rotationProgress - 0.92) / 0.08));
        bars.forEach(b => b.style.opacity = String(1 - shrink * 0.85));
      } else {
        bars.forEach(b => b.style.opacity = '');
      }
    }

    // ── Handoff 3: light → dark when exiting Payoff toward Video Stage ──
    function updateHandoff3() {
      if (!pacePayoffEl) return;
      const payoffRect = pacePayoffEl.getBoundingClientRect();
      const winH = window.innerHeight;
      // Exiting: payoff bottom is approaching viewport top
      const exiting = payoffRect.bottom < winH * 0.5 && payoffRect.bottom > -winH * 0.3;
      document.body.classList.toggle('payoff-exiting', exiting);
    }

    // ── Combined scroll handler (rAF-throttled) ──
    let ticking = false;
    function onScrollAll() {
      if (!ticking) {
        requestAnimationFrame(() => {
          updateScrollProgress();
          updateNav();
          updatePace();
          updateVideo();
          updateThreading();
          updateThreadQuiet();
          updateHandoff1();
          updateHandoff2();
          updateHandoff3();
          ticking = false;
        });
        ticking = true;
      }
    }
    window.addEventListener('scroll', onScrollAll, { passive: true });
    window.addEventListener('resize', onScrollAll, { passive: true });
    onScrollAll();

    // ── Copy outreach template (clipboard) ────
    const copyBtn = document.getElementById('copyBtn');
    const TEMPLATE = `Subject: Pilot interest — [Club / Team name]

Club or team:
Age group:
Roster size:
How you currently handle between-session training:
What you're trying to actually improve:

(Anything else you want us to know:)`;
    copyBtn.addEventListener('click', () => {
      const orig = copyBtn.textContent;
      const showResult = (text) => {
        copyBtn.textContent = text;
        setTimeout(() => { copyBtn.textContent = orig; }, 2200);
      };
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(TEMPLATE)
          .then(() => showResult('Copied — paste anywhere'))
          .catch(() => showResult('Copy failed — long-press to copy'));
      } else {
        // Fallback
        const ta = document.createElement('textarea');
        ta.value = TEMPLATE;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        try { document.execCommand('copy'); showResult('Copied — paste anywhere'); }
        catch { showResult('Copy failed'); }
        document.body.removeChild(ta);
      }
    });

  })();
</script>

</body>
</html>
