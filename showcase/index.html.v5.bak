    <div class="stack-list reveal">
      <div class="stack-row">
        <span class="s-name">React</span>
        <span class="s-note">One codebase. Three roles. Conditional routing instead of three apps.</span>
        <span class="s-version">19.2</span>
      </div>
      <div class="stack-row">
        <span class="s-name">Vite</span>
        <span class="s-note">Fast dev server; tight, code-split production build.</span>
        <span class="s-version">7.3</span>
      </div>
      <div class="stack-row">
        <span class="s-name">Tailwind CSS</span>
        <span class="s-note">Utility-first styling. No runtime, no CSS-in-JS tax.</span>
        <span class="s-version">4.2</span>
      </div>
      <div class="stack-row">
        <span class="s-name">Express</span>
        <span class="s-note">Thin API surface. Helmet, rate limiting, CORS — nothing extra.</span>
        <span class="s-version">5.2</span>
      </div>
      <div class="stack-row">
        <span class="s-name">better-sqlite3</span>
