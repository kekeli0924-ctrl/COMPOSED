        <span class="s-version">4.3</span>
      </div>
      <div class="stack-row">
        <span class="s-name">@google/genai</span>
        <span class="s-note">Multimodal model that reads the extracted frames — shots, passes, foot usage.</span>
        <span class="s-version">1.47</span>
      </div>
      <div class="stack-row">
        <span class="s-name">vite-plugin-pwa</span>
        <span class="s-note">Installable from a link. Offline-capable. No app store.</span>
        <span class="s-version">1.2</span>
      </div>
    </div>
  </div>
</section>

