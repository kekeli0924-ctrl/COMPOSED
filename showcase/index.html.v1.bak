<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="description" content="Composed — a soccer training companion that measures the work youth players do alone. Position-weighted progress. In-browser video analysis. No proprietary hardware." />
<meta name="theme-color" content="#0a0a0a" />
<title>Composed — Stop Guessing. Start Proving.</title>
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' fill='%230a0a0a'/><text x='50' y='72' font-size='72' font-family='Georgia,serif' font-style='italic' font-weight='500' fill='%23C2A56B' text-anchor='middle'>C</text></svg>" />
<style>
  :root {
    --bg: #0a0a0a;
    --bg-deep: #060606;
    --fg: #f5f5f7;
    --fg-mute: #86868b;
    --fg-soft: #6e6e73;
    --line: rgba(245,245,247,0.08);
    --line-soft: rgba(245,245,247,0.04);
    --accent: #C2A56B;
    --accent-hover: #D4B77D;
    --accent-soft: rgba(194,165,107,0.12);
    --serif: ui-serif, Georgia, "Times New Roman", serif;
    --sans: -apple-system, BlinkMacSystemFont, "Segoe UI", "Inter", "Helvetica Neue", sans-serif;
    --mono: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--bg);
    color: var(--fg);
    font-family: var(--sans);
    font-size: 19px;
    line-height: 1.6;
    font-weight: 400;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
    font-variant-numeric: tabular-nums;
    overflow-x: hidden;
  }
  ::selection { background: var(--accent); color: #0a0a0a; }

  img { max-width: 100%; display: block; }
  a { color: inherit; text-decoration: none; }
  button { font: inherit; color: inherit; background: none; border: none; cursor: pointer; }

  :focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
    border-radius: 2px;
  }

  /* ── Typography ─────────────────────────── */
  .display {
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 0.95;
    font-size: clamp(3rem, 9vw, 7.5rem);
  }
  .h2 {
    font-weight: 600;
    letter-spacing: -0.028em;
    line-height: 1.04;
    font-size: clamp(2.25rem, 5.5vw, 4.25rem);
  }
  .h3 {
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.15;
    font-size: clamp(1.5rem, 2.6vw, 2.1rem);
  }
  .serif-it {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 500;
  }
  .eyebrow {
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--accent);
  }
  .mute { color: var(--fg-mute); }
  .soft { color: var(--fg-soft); }

  p.body {
    font-size: clamp(1.05rem, 1.35vw, 1.3rem);
    color: var(--fg-mute);
    line-height: 1.6;
    max-width: 38em;
  }
  p.body strong { color: var(--fg); font-weight: 500; }

  /* ── Layout ─────────────────────────────── */
  section {
    padding: clamp(6rem, 14vh, 11rem) max(1.5rem, 5vw);
    position: relative;
  }
  .container { max-width: 80rem; margin: 0 auto; width: 100%; }
  .narrow { max-width: 56rem; margin: 0 auto; width: 100%; }

  /* ── Nav ─────────────────────────────────── */
  nav.top {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 50;
    padding: 1rem max(1.5rem, 5vw);
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(10,10,10,0);
    transition: background 0.3s ease, border-color 0.3s ease;
    border-bottom: 1px solid transparent;
  }
  nav.top.scrolled {
    background: rgba(10,10,10,0.72);
    backdrop-filter: saturate(1.4) blur(20px);
    -webkit-backdrop-filter: saturate(1.4) blur(20px);
    border-bottom-color: var(--line);
  }
  nav.top .logo {
    font-family: var(--serif);
    font-size: 1.6rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--fg);
  }
  nav.top .logo em { font-style: italic; color: var(--accent); font-weight: 500; }
  nav.top .nav-cta {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--fg-mute);
    padding: 0.5rem 1rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    transition: all 0.2s;
  }
  nav.top .nav-cta:hover { color: var(--fg); border-color: rgba(245,245,247,0.25); }

  /* ── Hero ────────────────────────────────── */
  header.hero {
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding: 10rem max(1.5rem, 5vw) 6rem;
    position: relative;
    overflow: hidden;
  }
  header.hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 40% at 80% 30%, rgba(194,165,107,0.08), transparent 60%),
      radial-gradient(ellipse 50% 50% at 15% 85%, rgba(194,165,107,0.04), transparent 60%);
    pointer-events: none;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(3rem, 7vw, 7rem);
    align-items: center;
    width: 100%;
    position: relative;
  }
  @media (max-width: 960px) {
    .hero-grid { grid-template-columns: 1fr; gap: 4rem; }
  }
  .hero h1 { margin-bottom: 1.5rem; }
  .hero .tagline {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.1rem, 1.4vw, 1.4rem);
    color: var(--accent);
    margin-bottom: 2rem;
    letter-spacing: 0.02em;
  }
  .hero .lede {
    font-size: clamp(1.15rem, 1.5vw, 1.5rem);
    color: var(--fg-mute);
    max-width: 30em;
    line-height: 1.5;
    margin-bottom: 2.5rem;
    font-weight: 400;
  }
  .hero .lede strong { color: var(--fg); font-weight: 500; }
  .cta-row { display: flex; gap: 0.8rem; flex-wrap: wrap; }
  .cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.9rem 1.5rem;
    font-size: 0.95rem;
    font-weight: 500;
    border-radius: 999px;
    transition: all 0.2s ease;
    white-space: nowrap;
  }
  .cta.primary {
    background: var(--fg);
    color: var(--bg);
  }
  .cta.primary:hover { background: var(--accent); color: var(--bg); }
  .cta.secondary {
    background: transparent;
    color: var(--fg);
    border: 1px solid var(--line);
  }
  .cta.secondary:hover { border-color: var(--fg-mute); }
  .cta .arrow { display: inline-block; transition: transform 0.25s ease; }
  .cta:hover .arrow { transform: translateX(3px); }

  /* Hero phone */
  .hero-phone {
    position: relative;
    width: min(100%, 22rem);
    aspect-ratio: 9 / 19.5;
    margin: 0 auto;
    border-radius: 2.6rem;
    padding: 0.55rem;
    background: linear-gradient(145deg, #2a2a2a 0%, #161616 100%);
    box-shadow:
      0 30px 60px rgba(0,0,0,0.5),
      0 0 0 1px rgba(245,245,247,0.04),
      inset 0 1px 0 rgba(245,245,247,0.06);
    transform: rotate(-1.5deg);
  }
  .hero-phone::before {
    content: "";
    position: absolute;
    top: 0.6rem; left: 50%;
    transform: translateX(-50%);
    width: 30%; height: 0.9rem;
    background: #000;
    border-radius: 999px;
    z-index: 2;
  }
  .hero-phone .phone-screen {
    width: 100%; height: 100%;
    border-radius: 2.05rem;
    overflow: hidden;
    background: #FAFAF8;
    position: relative;
  }
  .hero-phone .phone-screen img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: top;
  }

  /* ── Wrong Metric chapter ─────────────────── */
  .chapter-tension {
    background: var(--bg-deep);
    min-height: 90vh;
    display: flex;
    align-items: center;
  }
  .chapter-tension h2 {
    max-width: 24ch;
  }
  .chapter-tension h2 em {
    font-family: var(--serif);
    font-weight: 400;
    font-style: italic;
    color: var(--accent);
  }
  .chapter-tension .follow {
    margin-top: 2.5rem;
    font-size: clamp(1rem, 1.2vw, 1.2rem);
    color: var(--fg-mute);
    max-width: 36em;
    line-height: 1.6;
  }

  /* ── Pace chapter (scroll-pinned) ─────────── */
  .pace-stage {
    height: 320vh;
    position: relative;
    background: var(--bg);
  }
  .pace-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    align-items: center;
    padding: 3rem max(1.5rem, 5vw);
    overflow: hidden;
  }
  .pace-sticky::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 50% 80% at 70% 50%, rgba(194,165,107,0.06), transparent 60%);
    pointer-events: none;
  }
  .pace-inner {
    width: 100%;
    max-width: 80rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: clamp(2.5rem, 6vw, 6rem);
    align-items: center;
    position: relative;
  }
  @media (max-width: 900px) {
    .pace-inner { grid-template-columns: 1fr; gap: 2.5rem; }
  }
  .pace-left .eyebrow { margin-bottom: 1.2rem; }
  .pace-left h2 { margin-bottom: 1.5rem; }
  .pace-position-name {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 500;
    color: var(--accent);
  }
  .pace-caption {
    font-size: clamp(1.05rem, 1.3vw, 1.25rem);
    color: var(--fg-mute);
    max-width: 32em;
    line-height: 1.55;
    min-height: 4.8em;
    transition: opacity 0.4s ease;
  }
  .pace-caption strong { color: var(--fg); font-weight: 500; }

  /* Pace visualization */
  .pace-viz {
    background: #111;
    border: 1px solid var(--line);
    border-radius: 1.5rem;
    padding: clamp(1.5rem, 3vw, 2.5rem);
    position: relative;
  }
  .pace-viz-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 2rem;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .pace-viz-label {
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--fg-mute);
  }
  .pace-viz-position {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(1.3rem, 1.8vw, 1.7rem);
    font-weight: 500;
    color: var(--accent);
    transition: opacity 0.3s ease;
  }
  .pace-bars {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .pace-bar-row {
    display: grid;
    grid-template-columns: 6.5rem 1fr 3rem;
    gap: 0.9rem;
    align-items: center;
  }
  @media (max-width: 500px) {
    .pace-bar-row { grid-template-columns: 5rem 1fr 2.4rem; gap: 0.6rem; }
  }
  .pace-bar-label {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-mute);
  }
  .pace-bar-track {
    height: 6px;
    background: rgba(245,245,247,0.05);
    border-radius: 999px;
    overflow: hidden;
    position: relative;
  }
  .pace-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent) 0%, var(--accent-hover) 100%);
    border-radius: 999px;
    width: 0%;
    transition: width 0.7s cubic-bezier(0.25, 0.1, 0.25, 1);
    box-shadow: 0 0 20px rgba(194,165,107,0.3);
  }
  .pace-bar-pct {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--fg);
    text-align: right;
    transition: color 0.3s;
  }
  .pace-bar-row.dominant .pace-bar-label { color: var(--fg); }
  .pace-bar-row.dominant .pace-bar-pct { color: var(--accent); }

  .pace-viz-footer {
    margin-top: 2.25rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .pace-viz-footer-label {
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--fg-mute);
  }
  .pace-viz-footer-note {
    font-size: 0.85rem;
    color: var(--fg-soft);
    font-family: var(--sans);
  }

  /* Pace progress indicator (dots) */
  .pace-progress {
    position: absolute;
    left: max(1.5rem, 5vw);
    bottom: 2rem;
    display: flex;
    gap: 0.5rem;
  }
  @media (max-width: 900px) {
    .pace-progress { left: 50%; transform: translateX(-50%); bottom: 1rem; }
  }
  .pace-progress .dot {
    width: 6px; height: 6px;
    border-radius: 999px;
    background: rgba(245,245,247,0.15);
    transition: all 0.3s ease;
  }
  .pace-progress .dot.active {
    background: var(--accent);
    width: 20px;
  }

  /* ── Video chapter (scroll-pinned) ─────── */
  .video-stage {
    height: 320vh;
    position: relative;
    background: var(--bg-deep);
  }
  .video-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    align-items: center;
    padding: 3rem max(1.5rem, 5vw);
    overflow: hidden;
  }
  .video-inner {
    width: 100%;
    max-width: 80rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(2.5rem, 6vw, 6rem);
    align-items: center;
  }
  @media (max-width: 900px) {
    .video-inner { grid-template-columns: 1fr; gap: 2.5rem; }
  }
  .video-left .eyebrow { margin-bottom: 1.2rem; }
  .video-left h2 { margin-bottom: 1.5rem; }

  .video-stage-list {
    list-style: none;
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    counter-reset: step;
  }
  .video-stage-list li {
    display: grid;
    grid-template-columns: 2.6rem 1fr;
    gap: 1rem;
    padding: 1rem 0;
    border-top: 1px solid var(--line-soft);
    opacity: 0.38;
    transition: opacity 0.5s ease;
    counter-increment: step;
  }
  .video-stage-list li.active { opacity: 1; }
  .video-stage-list li::before {
    content: counter(step, decimal-leading-zero);
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: var(--accent);
    font-weight: 600;
    padding-top: 0.15rem;
  }
  .video-stage-list .stage-title {
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--fg);
    margin-bottom: 0.2rem;
  }
  .video-stage-list .stage-sub {
    font-size: 0.85rem;
    color: var(--fg-mute);
    line-height: 1.5;
  }

  .video-phone {
    position: relative;
    width: min(100%, 20rem);
    margin: 0 auto;
    aspect-ratio: 9 / 19.5;
    border-radius: 2.6rem;
    padding: 0.55rem;
    background: linear-gradient(145deg, #2a2a2a 0%, #161616 100%);
    box-shadow:
      0 30px 60px rgba(0,0,0,0.5),
      0 0 0 1px rgba(245,245,247,0.04);
  }
  .video-phone::before {
    content: "";
    position: absolute;
    top: 0.6rem; left: 50%;
    transform: translateX(-50%);
    width: 30%; height: 0.9rem;
    background: #000;
    border-radius: 999px;
    z-index: 3;
  }
  .video-phone-screen {
    position: relative;
    width: 100%; height: 100%;
    border-radius: 2.05rem;
    overflow: hidden;
    background: #FAFAF8;
  }
  .video-phone-screen img {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: top;
    transition: opacity 0.6s ease;
  }
  .video-phone-screen img.inactive { opacity: 0; }

  /* Analyzing overlay */
  .analyzing-overlay {
    position: absolute;
    inset: 0;
    background: rgba(10,10,10,0.80);
    backdrop-filter: blur(4px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    text-align: center;
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
    z-index: 2;
  }
  .analyzing-overlay.active { opacity: 1; }
  .analyzing-overlay .ao-spinner {
    width: 2.4rem; height: 2.4rem;
    border: 2px solid rgba(194,165,107,0.25);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: spin 1s linear infinite;
    margin-bottom: 1.25rem;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  .analyzing-overlay .ao-text {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--fg);
    letter-spacing: 0.03em;
    margin-bottom: 0.4rem;
  }
  .analyzing-overlay .ao-sub {
    font-size: 0.72rem;
    color: var(--fg-mute);
    font-family: var(--mono);
    letter-spacing: 0.05em;
  }

  /* ── Three Views (asymmetric) ───────────── */
  .three-views {
    padding-top: clamp(8rem, 15vh, 12rem);
  }
  .three-views .intro {
    max-width: 42rem;
    margin-bottom: 4rem;
  }
  .three-views .intro h2 { margin-top: 1rem; margin-bottom: 1.25rem; }
  .three-views .intro p.body { margin-top: 0.5rem; }

  .views-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    grid-template-rows: auto auto;
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }
  @media (max-width: 900px) {
    .views-grid { grid-template-columns: 1fr; }
  }
  .view-card {
    background: #111;
    border: 1px solid var(--line);
    border-radius: 1.4rem;
    overflow: hidden;
    padding: clamp(1.5rem, 2.5vw, 2rem);
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    transition: border-color 0.3s ease;
  }
  .view-card:hover { border-color: rgba(245,245,247,0.18); }

  .view-card.player {
    grid-column: 1; grid-row: 1 / span 2;
  }
  .view-card.coach { grid-column: 2; grid-row: 1; }
  .view-card.parent { grid-column: 2; grid-row: 2; }
  @media (max-width: 900px) {
    .view-card.player, .view-card.coach, .view-card.parent {
      grid-column: 1; grid-row: auto;
    }
  }

  .view-card h3 {
    font-size: clamp(1.4rem, 2vw, 1.8rem);
    margin-bottom: 0.3rem;
  }
  .view-card .view-role {
    font-size: 0.68rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--accent);
  }
  .view-card p {
    font-size: 0.98rem;
    color: var(--fg-mute);
    line-height: 1.55;
  }
  .view-card p strong { color: var(--fg); font-weight: 500; }

  .view-shot {
    position: relative;
    border-radius: 0.9rem;
    overflow: hidden;
    background: #FAFAF8;
    box-shadow: 0 12px 40px rgba(0,0,0,0.4);
    aspect-ratio: 9 / 16.5;
  }
  .view-card.player .view-shot { aspect-ratio: 9 / 17; }
  .view-shot img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: top;
  }

  .privacy-note {
    margin-top: 3rem;
    padding: 1.5rem 0 0;
    border-top: 1px solid var(--line);
    max-width: 46rem;
  }
  .privacy-note p {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(1.1rem, 1.4vw, 1.35rem);
    color: var(--fg-mute);
    line-height: 1.5;
  }
  .privacy-note p strong {
    color: var(--fg);
    font-style: normal;
    font-family: var(--sans);
    font-weight: 500;
  }

  /* ── Built With ─────────────────────────── */
  .built-with {
    background: var(--bg-deep);
  }
  .built-with h2 { margin-bottom: 1rem; }
  .built-with .intro p { margin-bottom: 3.5rem; }
  .stack-list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--line);
  }
  .stack-row {
    display: grid;
    grid-template-columns: 1fr 1.6fr auto;
    gap: 2rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--line);
    align-items: baseline;
    transition: background 0.2s ease;
  }
  .stack-row:hover { background: rgba(245,245,247,0.015); padding-left: 0.5rem; padding-right: 0.5rem; }
  @media (max-width: 720px) {
    .stack-row {
      grid-template-columns: 1fr auto;
      grid-template-areas: "name version" "note note";
      gap: 0.3rem 1rem;
    }
    .stack-row .s-name { grid-area: name; }
    .stack-row .s-version { grid-area: version; }
    .stack-row .s-note { grid-area: note; margin-top: 0.4rem; }
  }
  .stack-row .s-name {
    font-family: var(--mono);
    font-size: 0.95rem;
    color: var(--fg);
    font-weight: 500;
    letter-spacing: -0.005em;
  }
  .stack-row .s-note {
    font-size: 0.95rem;
    color: var(--fg-mute);
    line-height: 1.5;
  }
  .stack-row .s-version {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--fg-soft);
    letter-spacing: 0;
    white-space: nowrap;
  }

  /* ── Closing CTA ────────────────────────── */
  .close-section {
    min-height: 90vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    padding: 6rem max(1.5rem, 5vw);
  }
  .close-section::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 50% 50%, rgba(194,165,107,0.07), transparent 60%);
    pointer-events: none;
  }
  .close-inner {
    position: relative;
    text-align: center;
    max-width: 56rem;
    margin: 0 auto;
  }
  .close-inner .kicker {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.05rem, 1.35vw, 1.4rem);
    color: var(--accent);
    margin-bottom: 1.5rem;
    letter-spacing: 0.02em;
  }
  .close-inner .stay-composed {
    font-family: var(--serif);
    font-weight: 500;
    font-style: italic;
    font-size: clamp(3.5rem, 11vw, 9rem);
    letter-spacing: -0.035em;
    line-height: 0.95;
    margin-bottom: 2.5rem;
    color: var(--fg);
  }
  .close-inner p.pitch {
    font-size: clamp(1.1rem, 1.45vw, 1.45rem);
    color: var(--fg-mute);
    max-width: 36em;
    margin: 0 auto 3rem;
    line-height: 1.55;
  }
  .close-inner p.pitch strong { color: var(--fg); font-weight: 500; }
  .close-cta-row {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .close-cta-row .cta.primary {
    padding: 1.1rem 2rem;
    font-size: 1rem;
    background: var(--accent);
    color: #0a0a0a;
  }
  .close-cta-row .cta.primary:hover { background: var(--accent-hover); }

  /* ── Footer ─────────────────────────────── */
  footer {
    padding: 3rem max(1.5rem, 5vw) 4rem;
    border-top: 1px solid var(--line);
    background: var(--bg);
  }
  footer .f-inner {
    max-width: 80rem;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }
  footer .f-logo {
    font-family: var(--serif);
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--fg);
  }
  footer .f-logo em { font-style: italic; color: var(--accent); }
  footer .f-note {
    font-size: 0.8rem;
    color: var(--fg-soft);
  }

  /* ── Reveal animations (sparing) ───────── */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.9s cubic-bezier(0.2, 0.8, 0.3, 1), transform 0.9s cubic-bezier(0.2, 0.8, 0.3, 1);
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .reveal { opacity: 1; transform: none; transition: none; }
    html { scroll-behavior: auto; }
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
    }
  }

  /* ── Utility ────────────────────────────── */
  .spacer { height: 1px; }
</style>
</head>
<body>

<nav class="top" id="topNav" aria-label="Primary">
  <a href="#top" class="logo"><em>C</em>omposed</a>
  <a href="#contact" class="nav-cta">Contact</a>
</nav>

<header class="hero" id="top">
  <div class="hero-grid container">
    <div>
      <div class="tagline">Stay Composed.</div>
      <h1 class="display">Stop Guessing.<br/><span class="serif-it">Start Proving.</span></h1>
      <p class="lede">
        The hours you put in alone — in the backyard, on the wall, in the empty park — <strong>finally count.</strong>
        Real measurement for youth players who train between team sessions.
      </p>
      <div class="cta-row">
        <a href="#pace" class="cta primary">See how it works <span class="arrow">→</span></a>
        <a href="#contact" class="cta secondary">For coaches</a>
      </div>
    </div>
    <div class="hero-phone" aria-hidden="true">
      <div class="phone-screen">
        <img src="data:image/jpeg;base64," alt="" />
      </div>
    </div>
  </div>
</header>

<section class="chapter-tension">
  <div class="narrow reveal">
    <div class="eyebrow" style="margin-bottom: 1.5rem;">The wrong metric</div>
    <h2 class="h2">
      Most training apps give every player <em>the same score.</em>
    </h2>
    <p class="follow">
      A striker and a holding midfielder are not the same player. A goalkeeper is not a winger.
      When every position chases the same number, the number stops meaning anything.
    </p>
  </div>
</section>

<div class="pace-stage" id="pace">
  <div class="pace-sticky">
    <div class="pace-inner">
      <div class="pace-left">
        <div class="eyebrow">Pace · Weighted by position</div>
        <h2 class="h2">
          A <span id="paceRoleName" class="pace-position-name">Striker's</span><br/>Pace is different.
        </h2>
        <p class="pace-caption" id="paceCaption">
          For a <strong>Striker</strong>, <strong>40% of Pace comes from shooting.</strong>
          Miss a finishing session and the number moves — because the number actually knows what matters.
        </p>
      </div>
      <div class="pace-viz" aria-hidden="true">
        <div class="pace-viz-header">
          <span class="pace-viz-label">Position weighting</span>
          <span class="pace-viz-position" id="paceVizPosition">Striker</span>
        </div>
        <div class="pace-bars" id="paceBars">
          <!-- Populated by JS -->
        </div>
        <div class="pace-viz-footer">
          <span class="pace-viz-footer-label">Sums to 100%</span>
          <span class="pace-viz-footer-note">5 metrics · 6 positions · real weights from <span style="font-family:var(--mono);font-size:0.8em;">src/utils/pace.js</span></span>
        </div>
      </div>
    </div>
    <div class="pace-progress" aria-hidden="true">
      <span class="dot active"></span>
      <span class="dot"></span>
      <span class="dot"></span>
      <span class="dot"></span>
      <span class="dot"></span>
    </div>
  </div>
</div>

<div class="video-stage">
  <div class="video-sticky">
    <div class="video-inner">
      <div class="video-left">
        <div class="eyebrow">Video → Proof</div>
        <h2 class="h2">
          From phone video to <span class="serif-it">real stats.</span>
        </h2>
        <p class="body" style="margin-top: 1.5rem;">
          No smart ball. No tripod. No subscription to a device ecosystem.
          The compression and analysis happen <strong>inside the app</strong> before the video ever leaves the phone.
        </p>
        <ol class="video-stage-list" id="videoStages">
          <li class="active">
            <div>
              <div class="stage-title">Record or upload from the phone.</div>
              <div class="stage-sub">MP4, MOV, AVI, WebM. Up to 500 MB. Drop it on the page.</div>
            </div>
          </li>
          <li>
            <div>
              <div class="stage-title">Compress in the browser. Extract frames.</div>
              <div class="stage-sub">FFmpeg.wasm transcodes to 720p H.264 and pulls 10–50 key frames — all client-side.</div>
            </div>
          </li>
          <li>
            <div>
              <div class="stage-title">Counted from your footage. You confirm before saving.</div>
              <div class="stage-sub">Shots, goals, left/right foot split, pass attempts — read frame-by-frame, written into the form, never auto-saved.</div>
            </div>
          </li>
        </ol>
      </div>
      <div class="video-phone" aria-hidden="true">
        <div class="video-phone-screen">
          <img src="data:image/jpeg;base64," alt="" id="vpImg1" />
          <img src="data:image/jpeg;base64," alt="" id="vpImg2" class="inactive" />
          <div class="analyzing-overlay" id="analyzingOverlay">
            <div class="ao-spinner"></div>
            <div class="ao-text">Extracting frames…</div>
            <div class="ao-sub">30 frames · 720p · H.264</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<section class="three-views">
  <div class="container">
    <div class="intro reveal">
      <div class="eyebrow">One system, three views</div>
      <h2 class="h2">Player. Coach. Parent.</h2>
      <p class="body">
        The same codebase routes every role to a different dashboard.
        A player asks <em>"am I improving?"</em> A coach asks <em>"who's doing the work?"</em>
        A parent just wants to know their kid is okay.
      </p>
    </div>

    <div class="views-grid">
      <article class="view-card player reveal">
        <div>
          <div class="view-role">Player</div>
          <h3 class="h3">Audited, in plain English.</h3>
          <p>
            Every Pace number is tappable. The app shows <strong>exactly</strong> which sessions moved it,
            which metrics are dragging it down, and a sentence a parent or coach can read in fifteen seconds.
          </p>
        </div>
        <div class="view-shot">
          <img src="data:image/jpeg;base64," alt="Player's Pace audit view with a −33.7% stalling reading and plain-English explanation." />
        </div>
      </article>

      <article class="view-card coach reveal">
        <div>
          <div class="view-role">Coach</div>
          <h3 class="h3">The squad at a glance.</h3>
          <p>
            One scannable roster. Status dots for compliance, Pace pills for direction.
            The whole list loads in <strong>three batched queries</strong> — it scales.
          </p>
        </div>
        <div class="view-shot">
          <img src="data:image/jpeg;base64," alt="Coach's Squad Pulse dashboard listing six players with training counts and STALL status pills." />
        </div>
      </article>

      <article class="view-card parent reveal">
        <div>
          <div class="view-role">Parent</div>
          <h3 class="h3">Observation, not direction.</h3>
          <p>
            Three privacy toggles decide what the parent sees.
            The <strong>player</strong> holds the toggles — not the parent, not the coach.
          </p>
        </div>
        <div class="view-shot">
          <img src="data:image/jpeg;base64," alt="Parent dashboard showing their child's week summary, active program, and development goals." />
        </div>
      </article>
    </div>

    <div class="privacy-note reveal">
      <p>
        The parent sees what the player <strong>allows them</strong> to see — not the other way around.
      </p>
    </div>
  </div>
</section>

<section class="built-with">
  <div class="container">
    <div class="intro reveal">
      <div class="eyebrow">Built with</div>
      <h2 class="h2">Real stack. No smoke.</h2>
      <p class="body">
        Every dependency below is in <span style="font-family:var(--mono); font-size: 0.92em;">package.json</span>,
        pulling its weight. Versions are exact.
      </p>
    </div>

    <div class="stack-list reveal">
      <div class="stack-row">
        <span class="s-name">React</span>
        <span class="s-note">One codebase. Three roles. Conditional routing instead of three apps.</span>
        <span class="s-version">19.2</span>
      </div>
      <div class="stack-row">
        <span class="s-name">Vite</span>
        <span class="s-note">Fast dev server; tight, code-split production build.</span>
        <span class="s-version">7.3</span>
      </div>
      <div class="stack-row">
        <span class="s-name">Tailwind CSS</span>
        <span class="s-note">Utility-first styling. No runtime, no CSS-in-JS tax.</span>
        <span class="s-version">4.2</span>
      </div>
      <div class="stack-row">
        <span class="s-name">Express</span>
        <span class="s-note">Thin API surface. Helmet, rate limiting, CORS — nothing extra.</span>
        <span class="s-version">5.2</span>
      </div>
      <div class="stack-row">
        <span class="s-name">better-sqlite3</span>
        <span class="s-note">Synchronous SQLite. Zero-latency reads. Single-file portability.</span>
        <span class="s-version">12.6</span>
      </div>
      <div class="stack-row">
        <span class="s-name">@ffmpeg/ffmpeg</span>
        <span class="s-note">H.264 encoding inside the browser — the video never leaves the phone raw.</span>
        <span class="s-version">0.12</span>
      </div>
      <div class="stack-row">
        <span class="s-name">tus-js-client</span>
        <span class="s-note">Resumable uploads. Survives the subway tunnel.</span>
        <span class="s-version">4.3</span>
      </div>
      <div class="stack-row">
        <span class="s-name">@google/genai</span>
        <span class="s-note">Multimodal Gemini — extracts shots, passes, foot usage from the extracted frames.</span>
        <span class="s-version">1.47</span>
      </div>
      <div class="stack-row">
        <span class="s-name">vite-plugin-pwa</span>
        <span class="s-note">Installable from a link. Offline-capable. No app store.</span>
        <span class="s-version">1.2</span>
      </div>
    </div>
  </div>
</section>

<section class="close-section" id="contact">
  <div class="close-inner reveal">
    <div class="kicker">Stay Composed.</div>
    <div class="stay-composed">Coach a <br/>pilot cohort.</div>
    <p class="pitch">
      Composed is pre-launch. We're onboarding a small number of clubs for the first pilot cohort.
      Tell us your roster, your age group, and what you're trying to <strong>actually</strong> improve.
    </p>
    <div class="close-cta-row">
      <a href="mailto:hello@composed.soccer?subject=Composed%20pilot%20%E2%80%94%20interest&body=Club%20or%20team%3A%20%0A%0AAge%20group%3A%20%0A%0ARole%20(coach%20%2F%20club%20director%20%2F%20other)%3A%20%0A%0ARoster%20size%3A%20%0A%0AWhat%20you%27re%20trying%20to%20improve%3A%20%0A%0A"
         class="cta primary">
        Contact for pilots <span class="arrow">→</span>
      </a>
    </div>
  </div>
</section>

<footer>
  <div class="f-inner">
    <div class="f-logo"><em>C</em>omposed</div>
    <div class="f-note">A soccer training companion · Pre-launch</div>
  </div>
</footer>

<script>
  (function() {
    'use strict';

    // ── Nav scroll state ───────────────────────
    const nav = document.getElementById('topNav');
    function onScroll() {
      if (window.scrollY > 30) nav.classList.add('scrolled');
      else nav.classList.remove('scrolled');
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // ── Reveal on scroll ────────────────────────
    const revealIO = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          revealIO.unobserve(e.target);
        }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -5% 0px' });
    document.querySelectorAll('.reveal').forEach(el => revealIO.observe(el));

    // ── Pace chapter: scroll-linked position cycling ────
    // Real position weights from src/utils/pace.js
    const POSITIONS = [
      {
        key: 'Striker',
        label: "Striker's",
        weights: { shooting: 0.40, passing: 0.10, consistency: 0.20, duration: 0.10, load: 0.20 },
        dominant: 'shooting',
        caption: "For a <strong>Striker</strong>, <strong>40% of Pace comes from shooting.</strong> Miss a finishing session and the number moves — because the number actually knows what matters."
      },
      {
        key: 'Winger',
        label: "Winger's",
        weights: { shooting: 0.25, passing: 0.15, consistency: 0.20, duration: 0.15, load: 0.25 },
        dominant: 'load',
        caption: "A <strong>Winger's</strong> Pace leans hardest on <strong>load</strong> — it's a running position. Shooting still matters; volume matters more."
      },
      {
        key: 'CAM',
        label: "CAM's",
        weights: { shooting: 0.25, passing: 0.30, consistency: 0.20, duration: 0.10, load: 0.15 },
        dominant: 'passing',
        caption: "A <strong>CAM</strong> (attacking midfielder) is graded on <strong>passing first, then shooting</strong>. Creativity over finishing."
      },
      {
        key: 'CDM',
        label: "CDM's",
        weights: { shooting: 0.05, passing: 0.35, consistency: 0.25, duration: 0.15, load: 0.20 },
        dominant: 'passing',
        caption: "A <strong>CDM's</strong> shot accuracy is worth <strong>5%</strong>. Passing is worth <strong>35%</strong>. A defensive midfielder who passes well is improving — even if they never shoot."
      },
      {
        key: 'GK',
        label: "Goalkeeper's",
        weights: { shooting: 0.05, passing: 0.15, consistency: 0.30, duration: 0.20, load: 0.30 },
        dominant: 'load',
        caption: "A <strong>Goalkeeper's</strong> Pace is <strong>30% load, 30% consistency.</strong> Showing up and doing the physical work — that's the job."
      }
    ];

    const METRIC_LABELS = [
      { key: 'shooting',    label: 'Shooting' },
      { key: 'passing',     label: 'Passing' },
      { key: 'consistency', label: 'Consistency' },
      { key: 'duration',    label: 'Duration' },
      { key: 'load',        label: 'Load' }
    ];

    const paceBars = document.getElementById('paceBars');
    const paceCaption = document.getElementById('paceCaption');
    const paceVizPosition = document.getElementById('paceVizPosition');
    const paceRoleName = document.getElementById('paceRoleName');
    const paceProgress = document.querySelectorAll('.pace-progress .dot');

    // Build initial bars
    function buildBars() {
      paceBars.innerHTML = METRIC_LABELS.map(m => `
        <div class="pace-bar-row" data-metric="${m.key}">
          <span class="pace-bar-label">${m.label}</span>
          <div class="pace-bar-track"><div class="pace-bar-fill"></div></div>
          <span class="pace-bar-pct">0%</span>
        </div>
      `).join('');
    }

    buildBars();

    let currentIndex = -1;
    function setPosition(idx) {
      if (idx === currentIndex) return;
      currentIndex = idx;
      const pos = POSITIONS[idx];
      METRIC_LABELS.forEach(m => {
        const row = paceBars.querySelector(`[data-metric="${m.key}"]`);
        if (!row) return;
        const pct = Math.round(pos.weights[m.key] * 100);
        row.querySelector('.pace-bar-fill').style.width = (pct * 2.5) + '%';
        row.querySelector('.pace-bar-pct').textContent = pct + '%';
        row.classList.toggle('dominant', m.key === pos.dominant);
      });

      paceCaption.style.opacity = '0';
      paceVizPosition.style.opacity = '0';
      setTimeout(() => {
        paceCaption.innerHTML = pos.caption;
        paceVizPosition.textContent = pos.key;
        paceRoleName.textContent = pos.label;
        paceCaption.style.opacity = '1';
        paceVizPosition.style.opacity = '1';
      }, 200);

      paceProgress.forEach((dot, i) => dot.classList.toggle('active', i === idx));
    }

    // Scroll-link Pace chapter to position index
    const paceStage = document.querySelector('.pace-stage');
    function updatePaceFromScroll() {
      if (!paceStage) return;
      const rect = paceStage.getBoundingClientRect();
      const winH = window.innerHeight;
      // Progress 0..1 across the stage, accounting for sticky section height
      const scrollable = paceStage.offsetHeight - winH;
      const scrolled = -rect.top;
      const progress = Math.max(0, Math.min(1, scrolled / scrollable));
      const idx = Math.min(POSITIONS.length - 1, Math.floor(progress * POSITIONS.length));
      setPosition(idx);
    }
    setPosition(0);

    // ── Video chapter: scroll-linked stage crossfade ───
    const videoStage = document.querySelector('.video-stage');
    const vpImg1 = document.getElementById('vpImg1');
    const vpImg2 = document.getElementById('vpImg2');
    const analyzingOverlay = document.getElementById('analyzingOverlay');
    const videoStageLi = document.querySelectorAll('#videoStages li');

    function updateVideoFromScroll() {
      if (!videoStage) return;
      const rect = videoStage.getBoundingClientRect();
      const winH = window.innerHeight;
      const scrollable = videoStage.offsetHeight - winH;
      const scrolled = -rect.top;
      const progress = Math.max(0, Math.min(1, scrolled / scrollable));

      // 0–0.33: state 1 (upload surface)
      // 0.33–0.66: state 2 (analyzing overlay over upload)
      // 0.66–1.0: state 3 (session form)
      let activeStage = 0;
      if (progress >= 0.66) activeStage = 2;
      else if (progress >= 0.33) activeStage = 1;

      // Cross-fade phone image
      if (activeStage === 2) {
        vpImg1.classList.add('inactive');
        vpImg2.classList.remove('inactive');
      } else {
        vpImg1.classList.remove('inactive');
        vpImg2.classList.add('inactive');
      }

      // Analyzing overlay: only in middle segment
      if (activeStage === 1) analyzingOverlay.classList.add('active');
      else analyzingOverlay.classList.remove('active');

      // Stage list highlight
      videoStageLi.forEach((li, i) => {
        li.classList.toggle('active', i === activeStage);
      });
    }

    // ── Scroll handler (combined, rAF-throttled) ────
    let ticking = false;
    function onScrollAll() {
      if (!ticking) {
        requestAnimationFrame(() => {
          updatePaceFromScroll();
          updateVideoFromScroll();
          ticking = false;
        });
        ticking = true;
      }
    }
    window.addEventListener('scroll', onScrollAll, { passive: true });
    window.addEventListener('resize', onScrollAll, { passive: true });
    onScrollAll();

  })();
</script>

</body>
</html>
